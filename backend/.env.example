GITHUB_TOKEN="your_github_personal_access_token"
JIRA_TOKEN="your_jira_oauth_token"
JIRA_EMAIL="you@example.com"
SLACK_TOKEN="your_slack_bot_token"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_KEY="your_supabase_anon_key"
SYNC_INTERVAL_MINUTES=15
MODELS_CORP_KEY=your_models_corp_api_key
# Full URL for the Models Corp Claude API (e.g. https://your-internal-gateway/.../streamRawPredict)
MODELS_CORP_API_URL=
# Set to false when using internal API with self-signed cert (e.g. corporate VPN)
MODELS_CORP_SSL_VERIFY=true

# Jira base URL (e.g. https://your-org.atlassian.net)
JIRA_BASE_URL=https://your-org.atlassian.net
